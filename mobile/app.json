{
  "expo": {
    "name": "Pokemon TCG Identifier",
    "slug": "pokemon-tcg-identifier",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Use camera to scan Pokemon cards"
      }
    },
    "android": {
      "permissions": [
        "CAMERA"
      ]
    },
    "extra": {
      "apiBaseUrl": "http://192.168.1.80:8000"
    }
  }
}
